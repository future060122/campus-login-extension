{
  "manifest_version": 3,
  "name": "江职大校园网自动登录",
  "version": "1.0.0",
  "description": "江西职业技术大学校园网自动登录插件，支持断线检测与自动重连",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "http://10.31.0.10/*",
    "http://10.31.0.10:801/*",
    "https://www.baidu.com/*",
    "https://www.bing.com/*",
    "https://www.qq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://10.31.0.10/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "江职大校园网自动登录",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
